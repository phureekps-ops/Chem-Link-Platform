// ChemLink Platform — Identity & Company data model
// Build Sequence Step 1 (see System Design Document, Section 7 & 14.2)
// "Single Company, Multi-Role" model: one Company can activate both
// a BUYER role profile and a SELLER role profile (Section 14.1).

generator client {
  provider      = "prisma-client-js"
  // Explicit targets (not just "native") so the correct query engine is
  // bundled at `prisma generate` time regardless of whether the Alpine/musl
  // runtime can auto-detect its OpenSSL version — see Dockerfile comment
  // for the incident this fixes (Render Pre-Deploy failing on Node 20-alpine).
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleType {
  BUYER
  SELLER
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum VerificationDocType {
  TRADE_REGISTRATION      // หนังสือรับรองบริษัท
  HAZMAT_LICENSE          // ใบอนุญาตวัตถุอันตราย (ผู้ขาย)
  ISO_CERTIFICATE         // ใบรับรอง ISO/GMP (ผู้ขาย)
  AUTHORIZED_BUYER_LETTER // หนังสือมอบอำนาจผู้มีอำนาจจัดซื้อ (ผู้ซื้อ)
  OTHER
}

// Company: single legal entity identity, shared across all roles (Section 14.1)
model Company {
  id            String   @id @default(uuid())
  legalName     String
  taxId         String   @unique
  address       String?
  province      String?
  industryType  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  roles CompanyRole[]
  users User[]
  products Product[]
  buyerRfqs  Rfq[]  @relation("BuyerRfqs")
  sellerDeals Deal[] @relation("SellerDeals")
  creditWallet CreditWallet? // Section 14.5 — one wallet per company, not per role

  @@map("companies")
}

// CompanyRole: one row per activated role (BUYER and/or SELLER).
// Trust Score is composite per role (Section 15.1):
//   verificationScore 30% + ratingScore 50% + behavioralScore 20%
model CompanyRole {
  id                  String             @id @default(uuid())
  companyId           String
  company             Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  roleType            RoleType
  verificationStatus  VerificationStatus @default(PENDING)

  verificationScore   Float @default(0) // from KYC / document checks
  ratingScore         Float @default(0) // from Section 15 reviews (populated later)
  behavioralScore     Float @default(0) // from RFQ response rate etc (populated later)

  // Cached weighted sum (30/50/20 per Section 15.1), recomputed whenever
  // any component above changes — see CompositeTrustScoreService. Stored
  // (not computed on read) so search/sort by Trust Score (Section 5.2)
  // doesn't need to scan and compute for every row.
  compositeTrustScore Float @default(0)

  activatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents VerificationDocument[]

  @@unique([companyId, roleType]) // a company can only activate BUYER once, SELLER once
  @@map("company_roles")
}

// Verification documents attached to a specific role activation (Section 14.2)
model VerificationDocument {
  id            String              @id @default(uuid())
  companyRoleId String
  companyRole   CompanyRole         @relation(fields: [companyRoleId], references: [id], onDelete: Cascade)
  docType       VerificationDocType
  fileUrl       String
  status        VerificationStatus  @default(PENDING)
  reviewedNote  String?
  uploadedAt    DateTime            @default(now())

  @@map("verification_documents")
}

// User: individual login under a Company. allowedRoles is a subset of the
// company's activated CompanyRole types (Section 14.1 — per-user role access).
model User {
  id              String     @id @default(uuid())
  companyId       String
  company         Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email           String     @unique
  passwordHash    String
  fullName        String
  position        String?
  isCompanyAdmin  Boolean    @default(false)
  allowedRoles    RoleType[] // e.g. [SELLER] for a sales rep, [BUYER, SELLER] for an owner
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  refreshTokens RefreshToken[]
  createdRfqs   Rfq[]
  createdQuotes Quote[]
  dealMessages  DealMessage[]
  notifications Notification[]

  @@map("users")
}

// Refresh tokens stored hashed, revocable (used by /auth/refresh and /auth/logout)
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ============================================================
// Build Sequence Step 2 — Product Catalog & Document Library
// (System Design Document, Section 5.2, 5.3, 7)
// ============================================================

enum ProductDocType {
  SDS // Safety Data Sheet
  COA // Certificate of Analysis
  TDS // Technical Data Sheet
}

enum StockStatus {
  IN_STOCK
  MADE_TO_ORDER
  OUT_OF_STOCK
}

// The 10 industry categories from the business plan (Section 5.1).
// A table (not an enum) so Admin can add/reorder categories later
// without a schema migration (Step 9 — Admin panel).
model Category {
  id        String     @id @default(uuid())
  slug      String     @unique
  nameTh    String
  nameEn    String
  sortOrder Int        @default(0)
  parentId  String?
  parent    Category?  @relation("CategoryToChildren", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryToChildren")

  products Product[]
  rfqs     Rfq[]

  @@map("categories")
}

// Product: one listing by a SELLER-role company (Section 7).
// Structured spec fields live in ProductSpec so the "Enhanced TDS" tabs
// (Section 5.3) can hold different attributes per product type without
// a wide, mostly-empty products table.
model Product {
  id               String      @id @default(uuid())
  sellerCompanyId  String
  sellerCompany    Company     @relation(fields: [sellerCompanyId], references: [id], onDelete: Cascade)
  categoryId       String
  category         Category    @relation(fields: [categoryId], references: [id])

  name             String
  casNumber        String?
  grade            String?
  description      String?

  moqValue         Float?
  moqUnit          String? // e.g. "กก.", "ตัน", "ลิตร"
  priceMin         Float?
  priceMax         Float?
  priceUnit        String? // e.g. "บาท/กก."
  leadTimeDays     Int?
  stockStatus      StockStatus @default(MADE_TO_ORDER)

  isPublished      Boolean     @default(false) // draft until seller publishes
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  specs     ProductSpec[]
  documents ProductDocument[]
  rfqs      Rfq[]

  @@index([categoryId])
  @@index([sellerCompanyId])
  @@map("products")
}

// Structured technical properties, grouped to match the Enhanced TDS tabs:
// PHYSICAL_CHEMICAL / APPLICATION / REGULATORY / STORAGE_TRANSPORT
// (Section 5.3). Free-form key/value so different chemical types (resin
// vs. mineral vs. specialty chemical) don't need different table shapes.
enum ProductSpecGroup {
  PHYSICAL_CHEMICAL
  APPLICATION
  REGULATORY
  STORAGE_TRANSPORT
}

model ProductSpec {
  id        String           @id @default(uuid())
  productId String
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  group     ProductSpecGroup
  label     String           // e.g. "ความบริสุทธิ์ (Purity)"
  value     String           // e.g. "99.2%" — kept as string, unit included
  sortOrder Int              @default(0)

  @@index([productId])
  @@map("product_specs")
}

// SDS / COA / TDS documents attached to a product (Section 5.3 document
// library). Distinct from VerificationDocument (Step 1), which verifies
// the *company*, not a specific product.
model ProductDocument {
  id           String         @id @default(uuid())
  productId    String
  product      Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  docType      ProductDocType
  fileUrl      String
  version      String?
  issuedAt     DateTime?
  uploadedAt   DateTime       @default(now())

  @@index([productId])
  @@map("product_documents")
}

// ============================================================
// Build Sequence Step 4 — RFQ / Deal Room
// (System Design Document, Section 6, 7, 14.4)
// ============================================================

// Buyer-facing overall status of an RFQ (Section 6 workflow, 8 steps).
// This is a summary derived from the state of its Deals; RATED is set
// once a review is submitted for the winning Deal (Step 9 wires that up).
enum RfqStatus {
  DRAFT
  SUBMITTED
  ACKNOWLEDGED
  QUOTED
  NEGOTIATING
  VERIFICATION
  CLOSED_WON
  CLOSED_LOST
  CANCELLED
  RATED
}

enum RfqDistributionType {
  TARGETED // ส่งถึงผู้ขายที่เลือกไว้เอง
  MARKET   // RFQ Market — จับคู่ผู้ขายที่ตรงสเปกอัตโนมัติ (Section 6 note)
}

// Per-seller status within one Deal (Section 5.5). A single RFQ can have
// many Deals (one per invited/matched seller); each negotiates
// independently — this is what deal-room.html renders one of.
enum DealStatus {
  INVITED
  ACKNOWLEDGED
  QUOTED
  NEGOTIATING
  WON
  LOST
  DECLINED
}

enum DealMessageType {
  TEXT
  QUOTE
  DOCUMENT
  SYSTEM
}

// RFQ: a buyer's request. Section 6, step 1 (สร้างคำขอ RFQ).
model Rfq {
  id               String              @id @default(uuid())
  buyerCompanyId   String
  buyerCompany     Company             @relation("BuyerRfqs", fields: [buyerCompanyId], references: [id], onDelete: Cascade)
  createdByUserId  String
  createdByUser    User                @relation(fields: [createdByUserId], references: [id])

  // Spec fields (Section 5.4 step 1). productId is optional — a buyer can
  // RFQ something not yet listed in the catalog, using free-text fields.
  productId        String?
  product          Product?            @relation(fields: [productId], references: [id])
  categoryId       String
  category         Category            @relation(fields: [categoryId], references: [id])
  productName      String
  casNumber        String?
  gradeRequirement String?
  purityRequirement String?

  quantityValue      Float
  quantityUnit       String
  deliveryLocation   String
  deliveryDeadline   DateTime?
  paymentTermsNote   String?
  notes              String?

  distributionType RfqDistributionType @default(TARGETED)
  status           RfqStatus           @default(DRAFT)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  submittedAt DateTime?

  deals Deal[]
  notifications Notification[]
}

// One Deal per RFQ-seller pair (Section 7: "Deal / Negotiation"). This is
// the unit that deal-room.html represents — its own thread + quotes.
model Deal {
  id              String     @id @default(uuid())
  rfqId           String
  rfq             Rfq        @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  sellerCompanyId String
  sellerCompany   Company    @relation("SellerDeals", fields: [sellerCompanyId], references: [id], onDelete: Cascade)
  status          DealStatus @default(INVITED)

  // How this seller ended up on the RFQ — buyer-picked (TARGETED) or
  // matched by the rule-based engine (MARKET). See Section 10: MVP scope
  // is rule-based matching, not full AI, for Step 4.
  matchedViaMarket Boolean @default(false)

  acknowledgedAt DateTime?
  closedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  quotes   Quote[]
  messages DealMessage[]
  notifications Notification[]

  @@unique([rfqId, sellerCompanyId]) // a seller can only have one Deal per RFQ
  @@index([sellerCompanyId])
  @@map("deals")
}

// A versioned quote within a Deal (Section 5.5 "quote revision card" —
// ใบเสนอราคา ฉบับที่ 1, 2, ...). Never updated in place; a revision is a
// new row, so the full negotiation history is preserved.
model Quote {
  id              String    @id @default(uuid())
  dealId          String
  deal            Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  version         Int
  price           Float
  priceUnit       String
  paymentTerms    String
  leadTimeDays    Int
  moqValue        Float?
  validUntil      DateTime?
  createdByUserId String
  createdByUser   User      @relation(fields: [createdByUserId], references: [id])
  createdAt       DateTime  @default(now())

  messages DealMessage[]

  @@unique([dealId, version])
  @@index([dealId])
  @@map("quotes")
}

// One entry in a Deal's negotiation thread (Section 5.5). type=QUOTE
// entries point at the Quote they announce; type=SYSTEM entries are
// auto-generated (e.g. "สร้างคำขอ RFQ · ...") and have no sender.
model DealMessage {
  id              String          @id @default(uuid())
  dealId          String
  deal            Deal            @relation(fields: [dealId], references: [id], onDelete: Cascade)
  type            DealMessageType
  senderUserId    String?
  senderUser      User?           @relation(fields: [senderUserId], references: [id])
  content         String?
  attachmentUrl   String?
  relatedQuoteId  String?
  relatedQuote    Quote?          @relation(fields: [relatedQuoteId], references: [id])
  createdAt       DateTime        @default(now())

  @@index([dealId])
  @@map("deal_messages")
}

// ============================================================
// Build Sequence Step 5 — Notifications
// (System Design Document, Section 5.6, 5.7, 14.3, 16.2 step 5)
// ============================================================

enum NotificationType {
  RFQ_RECEIVED      // seller: a new RFQ was assigned to their company
  DEAL_ACKNOWLEDGED // buyer: a seller acknowledged their RFQ
  QUOTE_RECEIVED    // buyer: a new or revised quote arrived
  MESSAGE_RECEIVED  // either side: a new Deal Room message
  DEAL_CLOSED_WON   // seller: they won the deal
  DEAL_CLOSED_LOST  // seller: another seller won instead
}

// In-app notifications (Section 5.6/5.7 "Unified Notification Center").
// Email/LINE/push are separate delivery channels layered on top of this
// same event — see NotificationsService — but this table is always
// written first and is the source of truth the frontend inbox reads.
model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  dealId    String?
  deal      Deal?            @relation(fields: [dealId], references: [id], onDelete: SetNull)
  rfqId     String?
  rfq       Rfq?             @relation(fields: [rfqId], references: [id], onDelete: SetNull)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

// ============================================================
// Build Sequence Step 6 — Credit & Billing System
// (System Design Document, Section 13, 14.5, 16.2 step 6)
//
// Scope for this step (see chemlink-backend/README.md for the full note):
// the Billing & Metering Layer core (Wallet, Ledger, Rate Card, atomic
// debit) plus the free-quota-vs-wallet split from Section 13.4. Payment
// Gateway Integration, Tax Invoice Generator, Auto Top-up and Fraud
// Detection (Section 13.2's remaining Billing & Metering Layer rows) are
// deferred — they depend on picking a real payment provider and, in the
// Admin Credit Console's case, on the Admin panel/auth that doesn't exist
// yet (Section 8 roadmap). Redis-backed balance caching (Section 13.5
// performance risk) is Step 7+ per the .env.example note next to
// REDIS_URL — this step's atomicity comes from a conditional UPDATE
// (`WHERE balance >= cost`), not a cache.
// ============================================================

enum SubscriptionTier {
  BASIC
  PRO
  ENTERPRISE
}

// Section 13.4 — "Subscription + Credit แบบผสม": each tier bundles a
// monthly free-credit quota; usage beyond quota debits the CreditWallet.
model SubscriptionPlan {
  id                 String           @id @default(uuid())
  tier               SubscriptionTier @unique
  nameTh             String
  monthlyFreeCredits Int
  priceMonthly       Decimal          @db.Decimal(12, 2)
  priceYearly        Decimal          @db.Decimal(12, 2)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  wallets CreditWallet[]

  @@map("subscription_plans")
}

// One wallet per Company (Section 14.5: "Credit Wallet ยังคงเป็นกระเป๋าเดียว
// ต่อบริษัท" — explicitly NOT per role, even for dual-role companies).
// monthlyFreeQuota is a snapshot of the plan's quota, copied in whenever
// the plan changes or the monthly cycle resets, so the atomic quota-usage
// check below never needs to join SubscriptionPlan.
model CreditWallet {
  id                   String            @id @default(uuid())
  companyId            String            @unique
  company              Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  planId               String?
  plan                 SubscriptionPlan? @relation(fields: [planId], references: [id])
  balance              Int               @default(0)
  monthlyFreeQuota     Int               @default(0)
  monthlyFreeQuotaUsed Int               @default(0)
  quotaResetAt         DateTime          @default(now())
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  transactions CreditTransaction[]

  @@map("credit_wallets")
}

// Section 13.1's three-tier policy table. QUOTA_ELIGIBLE (tier 2 — free
// monthly quota, then wallet) vs ALWAYS_CHARGED (tier 3 — no quota, ever)
// is a business rule, not a schema fact — see CreditsService.QUOTA_ELIGIBLE_ACTIONS.
// Only SEND_RFQ is wired into an actual endpoint so far (RfqService.submit);
// the rest exist here so rates can be set ahead of those features shipping
// (download full SDS/COA/TDS, Sourcing Assistant, Deal Room, price-index
// export, contact unlock, market intelligence, lead unlock — see README).
enum CreditActionType {
  SEND_RFQ
  DOWNLOAD_TECH_DOCUMENT
  AI_SOURCING_QUERY
  DEAL_ROOM_ACCESS
  EXPORT_PRICE_INDEX
  UNLOCK_CONTACT
  MARKET_INTELLIGENCE_REPORT
  UNLOCK_LEAD
}

enum CreditTxnType {
  DEBIT  // wallet balance charge (quota-covered usage does NOT create a DEBIT — see fromQuota)
  CREDIT // top-up / admin grant
  REFUND // credit returned, e.g. reversing a charge for an action that failed downstream
}

// Immutable ledger (Section 13.2 "Credit Ledger (Immutable)"). Application
// code only ever INSERTs here — see the comment on CreditsService for the
// enforcement note. One row per metered event, whether it drew from the
// free quota or the wallet balance, so usage can be reported either way
// (Section 13.2 Usage Analytics Dashboard / 14.5 role breakdown).
model CreditTransaction {
  id                String            @id @default(uuid())
  walletId          String
  wallet            CreditWallet      @relation(fields: [walletId], references: [id])
  type              CreditTxnType
  amount            Int               // always positive; `type` carries the sign
  actionType        CreditActionType?
  fromQuota         Boolean           @default(false) // true = paid from the free monthly quota, not wallet balance
  roleContext       RoleType?         // Section 14.5 — usage broken out by BUYER/SELLER activity
  relatedEntityType String?           // e.g. "Rfq"
  relatedEntityId   String?
  balanceAfter      Int               // wallet.balance snapshot after this txn (unchanged if fromQuota)
  note              String?
  createdAt         DateTime          @default(now())

  @@index([walletId, createdAt])
  @@map("credit_transactions")
}

// Section 13.2 "Credit Rate Card" — admin-editable without code changes.
// Versioned by effectiveFrom so a past CreditTransaction always reflects
// the rate actually charged at the time, even after prices change later.
model CreditRateCard {
  id            String           @id @default(uuid())
  actionType    CreditActionType
  creditsCost   Int
  effectiveFrom DateTime         @default(now())
  createdAt     DateTime         @default(now())

  @@index([actionType, effectiveFrom])
  @@map("credit_rate_cards")
}

// Section 13.2 "Top-up & Package Store" catalog. Purchasing a package
// (payment collection) is deferred pending a payment provider decision —
// see README; this table exists so the catalog can be defined and
// displayed ahead of that integration.
model CreditPackage {
  id           String   @id @default(uuid())
  name         String
  creditAmount Int
  priceThb     Decimal  @db.Decimal(12, 2)
  bonusCredits Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("credit_packages")
}



