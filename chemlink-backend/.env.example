# App
NODE_ENV=development
PORT=3000

# Database (matches docker-compose service "postgres")
DATABASE_URL="postgresql://chemlink:chemlink_dev_password@localhost:5432/chemlink_dev?schema=public"

# Redis (matches docker-compose service "redis") — reserved for Step 7+ (credit metering cache)
REDIS_URL="redis://localhost:6379"

# Auth
JWT_ACCESS_SECRET="change-me-access-secret-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret-in-production"
JWT_REFRESH_EXPIRES_IN="30d"

# CORS
CORS_ORIGIN="http://localhost:3001"
